php_value upload_max_filesize 10M
php_value post_max_size 20M

# 安全响应头
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ========== 浏览器缓存优化 ==========
<IfModule mod_expires.c>
    ExpiresActive On

    # 图片缓存 30 天
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/gif "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    ExpiresByType image/x-icon "access plus 30 days"

    # CSS/JS 缓存 7 天
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType text/javascript "access plus 7 days"

    # 字体缓存 30 天
    ExpiresByType font/woff2 "access plus 30 days"
    ExpiresByType font/woff "access plus 30 days"
    ExpiresByType font/ttf "access plus 30 days"
    ExpiresByType application/font-woff2 "access plus 30 days"
</IfModule>

# 备用：通过 Cache-Control 设置缓存（mod_expires 不可用时）
<IfModule mod_headers.c>
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
        Header set Cache-Control "max-age=2592000, public"
    </FilesMatch>
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "max-age=604800, public"
    </FilesMatch>
    <FilesMatch "\.(woff2|woff|ttf)$">
        Header set Cache-Control "max-age=2592000, public"
    </FilesMatch>
</IfModule>

# HTML 页面缓存 - 首页缓存 5 分钟，其他页面不缓存
<IfModule mod_headers.c>
    <FilesMatch "^index\.php$">
        Header set Cache-Control "public, max-age=300"
    </FilesMatch>
    <FilesMatch "detail\.php$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>

# Gzip 压缩
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript text/javascript application/json application/xml text/xml application/rss+xml application/atom+xml image/svg+xml

    # 排除已压缩的内容
    SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp|zip|gz|bz2)$ no-gzip
</IfModule>

# ========== 跳转页 QQ/微信 UA 拦截 ==========
<IfModule mod_rewrite.c>
    RewriteEngine On

    # 仅对 redirect/ 目录下的请求生效
    RewriteCond %{REQUEST_URI} ^/redirect/
    # 检测 QQ 或微信 User-Agent
    RewriteCond %{HTTP_USER_AGENT} (QQ/|MicroMessenger) [NC]
    # 重写到 browser-tip-inline.php（内联提示页，无需额外请求）
    RewriteRule ^redirect/(.*)$ redirect/browser-tip-inline.php [L]
</IfModule>

# 禁止访问敏感目录
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(data|includes|uploads)/ - [F,L]
</IfModule>
